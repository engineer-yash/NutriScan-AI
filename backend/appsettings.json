{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "ConnectionStrings": {
        "DefaultConnection": "REPLACE_WITH_YOUR_DATABASE_CONNECTION_STRING"
    },
    "Jwt": {
        "Key": "REPLACE_WITH_SECURE_RANDOM_KEY_AT_LEAST_32_CHARACTERS_LONG",
        "Issuer": "AIProductFinder",
        "Audience": "AIProductFinderUsers",
        "ExpiryMinutes": 120
    },
    "AzureOpenAI": {
        "Endpoint": "REPLACE_WITH_YOUR_AZURE_OPENAI_ENDPOINT",
        "ApiKey": "REPLACE_WITH_YOUR_AZURE_OPENAI_API_KEY",
        "DeploymentName": "gpt-4o"
    },
    "AzureVision": {
        "Endpoint": "REPLACE_WITH_YOUR_AZURE_VISION_ENDPOINT",
        "ApiKey": "REPLACE_WITH_YOUR_AZURE_VISION_API_KEY"
    },
    "AzureBlob": {
        "ConnectionString": "REPLACE_WITH_YOUR_AZURE_BLOB_CONNECTION_STRING",
        "ContainerName": "nutriscan-images"
    }
}